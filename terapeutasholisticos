        .seccion-contenido { display: none; max-width: 900px; margin: 0 auto; }
        .seccion-contenido.activa { display: block; animation: fadeIn 0.5s ease; }
        .card-acceso { background: white; padding: 40px; border-radius: 30px; border: 2px solid var(--azul); text-align: center; margin-bottom: 40px; box-shadow: 0 15px 35px rgba(58,123,213,0.1); }
        .btn-zoom { display: inline-flex; align-items: center; gap: 10px; background: var(--azul); color: white; padding: 18px 40px; border-radius: 50px; text-decoration: none; font-weight: 700; font-size: 16px; margin-top: 20px; transition: 0.3s; border:none; cursor:pointer; }
        .btn-zoom:hover { transform: translateY(-3px); background: #2A5FB0; }
        .info-clase { background: white; padding: 40px; border-radius: 30px; border: 1px solid #eee; margin-bottom: 30px; }
        .info-clase h3 { font-family: 'Lora', serif; color: var(--verde); border-left: 4px solid var(--salmon); padding-left: 15px; margin-top: 30px; }
        .badge-live { display: inline-block; padding: 5px 12px; background: #ffebee; color: #d32f2f; border-radius: 5px; font-size: 11px; font-weight: 800; text-transform: uppercase; margin-bottom: 10px; }
        .hoja-ruta { border-left: 3px solid #E9F0F8; padding-left: 45px; margin-left: 15px; position: relative; }
        .ruta-paso { margin-bottom: 30px; background: #F8FAFD; padding: 25px; border-radius: 20px; border: 1px solid #EDF2F9; position: relative; }
        .ruta-paso::before { content: ''; position: absolute; left: -59px; top: 25px; width: 24px; height: 24px; background: var(--azul); border-radius: 50%; border: 5px solid white; box-shadow: 0 4px 10px rgba(58,123,213,0.3); }
        @media (max-width: 900px) {
            .header-movil { display: flex; }
            .sidebar-aula { transform: translateX(-100%); width: 280px; }
            .sidebar-aula.abierta { transform: translateX(0); }
            .contenido-aula { margin-left: 0; padding: 20px 5%; }
            .overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 10000; }
            .overlay.activa { display: block; }
        }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>

    <div id="puerta-acceso" style="position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: var(--azul); z-index: 20000; display: flex; justify-content: center; align-items: center; padding: 20px; box-sizing: border-box;">
        <div style="background: white; padding: 40px; border-radius: 40px; max-width: 400px; width: 100%; text-align: center;">
