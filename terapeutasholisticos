            <div class="info-clase"><h3>Introducción</h3><p>Cierre pedagógico y síntesis del recorrido formativo.</p></div>
        </div>

    </main>

    <script>
        const fechasApertura = {
            'e1': new Date(2026, 3, 1), 'e2': new Date(2026, 4, 1), 'e3': new Date(2026, 5, 1),
            'e4': new Date(2026, 6, 1), 'e5': new Date(2026, 7, 1), 'e6': new Date(2026, 8, 1),
            'e7': new Date(2026, 9, 1), 'e8': new Date(2026, 10, 1), 'e9': new Date(2026, 11, 1)
        };

        function verificarBloqueos() {
            const hoy = new Date();
            for (const id in fechasApertura) {
                const itemMenu = document.getElementById('menu-' + id);
                if (hoy < fechasApertura[id]) itemMenu.classList.add('bloqueado');
            }
        }

        function toggleMenu() { document.getElementById('sidebar').classList.toggle('abierta'); document.getElementById('overlay').classList.toggle('activa'); }

        function mostrarSeccion(id, elementoMenu) {
            const hoy = new Date();
            if (id !== 'home' && hoy < fechasApertura[id]) {
                alert("Este encuentro se habilitará el primer día del mes correspondiente.");
                return;
            }
            document.querySelectorAll('.seccion-contenido').forEach(s => s.classList.remove('activa'));
            document.getElementById(id).classList.add('activa');
            document.querySelectorAll('.item-encuentro').forEach(i => i.classList.remove('activo'));
            elementoMenu.classList.add('activo');
            if(window.innerWidth < 900) toggleMenu();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function verificarAcceso() {
            if (document.getElementById('input-password').value === "holismo2026") {
                sessionStorage.setItem("accesoPermitido", "true");
                document.getElementById('puerta-acceso').style.display = "none";
            } else { document.getElementById('error-msg').style.display = "block"; }
        }

        window.onload = function() {
            if (sessionStorage.getItem("accesoPermitido") === "true") document.getElementById('puerta-acceso').style.display = "none";
            verificarBloqueos();
        };
    </script>
</body>
</html>
